# ─── UIT Portfolio Studio — default configuration ───
# Copy to .env and adjust:  cp .env.default .env

# ─── Server ───
PORT=8000

# Where projects (uploads, generated docs, transcripts) are stored.
# Defaults to ~/.uit-portfolio if unset.
# UIT_DATA_DIR=/var/lib/uit-portfolio

# ─── Claude backend ───
# The app always prefers the Claude Code CLI when the binary is found
# (~/.local/bin/claude, ~/bin/claude, or PATH). For an OSU-approved inference
# boundary, point the CLI at AWS Bedrock by setting these in the environment —
# Claude Code itself reads them; there is no separate SDK path here:
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_PROFILE=uit-portfolio
# AWS_DEFAULT_REGION=us-west-2
# ANTHROPIC_DEFAULT_SONNET_MODEL=global.anthropic.claude-sonnet-4-6
# ANTHROPIC_DEFAULT_OPUS_MODEL=global.anthropic.claude-opus-4-6-v1
#
# Set inside a Claude Code session — forces DEMO mode (nested CLI calls crash).
# CLAUDECODE=
#
# Model passed to `claude --model` for every turn. Defaults to the 1M-token
# context window Opus: "claude-opus-4-8[1m]". The "[1m]" suffix selects the
# 1M-context variant. Override to "sonnet" for faster/cheaper runs, or another
# full model id. Drop the "[1m]" for the standard 200K context window.
# UIT_CLAUDE_MODEL=claude-opus-4-8[1m]
#
# Reasoning effort passed to `claude --effort`. Defaults to "high".
# Options: low | medium | high | xhigh | max.
# UIT_CLAUDE_EFFORT=high
#
# When no CLI is found, the app runs in DEMO mode: a scripted interview that
# still generates a real .docx via the skill, so it is fully runnable offline.

# ─── App branding / runtime injection (optional) ───
# Shown in the UI so the skill never has to hard-code OSU contacts.
# PORTFOLIO_COORDINATOR=UIT Portfolio Team <portfolio@example.edu>
# CONTACT=
